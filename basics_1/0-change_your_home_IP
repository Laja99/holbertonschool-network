#!/usr/bin/env bash
# Script to update /etc/hosts so that localhost resolves to 127.0.0.2 and facebook.com to 8.8.8.8

sudo sed -i 's/.*localhost$/127.0.0.2    localhost/' /etc/hosts
sudo sed -i 's/.*facebook.com$/8.8.8.8      facebook.com/' /etc/hosts

if ! grep -q "127.0.0.2    localhost" /etc/hosts; then
    echo "127.0.0.2    localhost" | sudo tee -a /etc/hosts > /dev/null
fi

if ! grep -q "8.8.8.8      facebook.com" /etc/hosts; then
    echo "8.8.8.8      facebook.com" | sudo tee -a /etc/hosts > /dev/null
fi
